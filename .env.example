# Environment Configuration for Document Generator
# Copy this file to .env and fill in your actual values

# LLM Provider Selection
# Options: gemini, openai, openrouter
LLM_PROVIDER=gemini

# Google Gemini Configuration (recommended)
GEMINI_API_KEY=AIzaSyAnp6LWThz3BrypBq9ce9qmfFEndzUs7lU
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.1
GEMINI_MAX_TOKENS=8000

# LLM API Configuration (OpenRouter with DeepSeek)
OPENAI_API_KEY=your_openrouter_api_key_here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_MODEL=deepseek/deepseek-v3
OPENAI_TEMPERATURE=0
OPENAI_MAX_TOKENS=2000

# Optional model profiles for side-by-side comparison
DEEPSEEK_SMALL_MODEL=deepseek/deepseek-r1-distill-qwen-7b
QWEN_SMALL_MODEL=qwen/qwen2.5-7b-instruct
MODEL_BENCHMARK_RUNS=1

# Alternative: Direct OpenAI (comment out BASE_URL above and use these)
# OPENAI_API_KEY=sk-your-direct-openai-key
# OPENAI_MODEL=gpt-4
# OPENAI_TEMPERATURE=0.1

# Alternative LLM Providers (uncomment if using)
# ANTHROPIC_API_KEY=your_anthropic_key_here
# AZURE_OPENAI_API_KEY=your_azure_key_here
# AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here

# Application Settings
APP_NAME=Document Generator
APP_VERSION=1.0.0
DEBUG=False

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# File Upload Settings
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=.doc,.docx,.pdf

# Output Settings
OUTPUT_DIR=./output
TEMPLATE_DIR=./app/templates
